# ════════════════════════════════════════════════
#  BookRAG — Cấu hình LLM
#  Sao chép file này thành .env rồi điền key
# ════════════════════════════════════════════════

# Chọn provider (chỉ điền 1 trong 3):
#   gemini  → Google Gemini (FREE, khuyến nghị)
#   groq    → Groq           (FREE, nhanh nhất)
#   openai  → OpenAI GPT     (trả phí)
#   (để trống) → Demo mode, không cần key
LLM_PROVIDER=gemini

# ── GEMINI (free) ────────────────────────────────
# Lấy key tại: https://aistudio.google.com/apikey
# Free: 15 req/phút, 1500 req/ngày
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.0-flash

# ── GROQ (free) ──────────────────────────────────
# Lấy key tại: https://console.groq.com/keys
# Free: 30 req/phút, model LLaMA 3 / Gemma 2
GROQ_API_KEY=your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ── OPENAI (trả phí) ─────────────────────────────
# Lấy key tại: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-3.5-turbo
